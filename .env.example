# Frontend env (copy to .env.local — gitignored). Names per PROJECT_SPEC.md §8.
# For local dev, run `supabase start` and copy the URL + anon key from `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# API-Sports widgets key (optional — widgets are hidden and custom Supabase
# views are used when unset). NEXT_PUBLIC_ means it is EXPOSED CLIENT-SIDE by
# design: domain-restrict this key in the API-Sports dashboard. Do NOT reuse
# the worker's API_FOOTBALL_KEY here.
NEXT_PUBLIC_API_FOOTBALL_WIDGET_KEY=

# Used only by the Python worker (never by Next.js):
# API_FOOTBALL_KEY=
# SUPABASE_SERVICE_KEY=
